# ──────────────────────────────────────────────────────────────────────────────
# .env.example — Plantilla de variables de entorno (NO contiene secretos reales)
# Copiar a .env y completar con valores reales. Nunca versionar .env
# ──────────────────────────────────────────────────────────────────────────────

# ─── Base de datos ────────────────────────────────────────────────────────────
# Usar contraseña aleatoria de ≥32 caracteres en producción
DATABASE_URL=postgres://postgres:CHANGE_ME_STRONG_PASSWORD@localhost:5432/postgres?options=--search_path=pharmacy

# ─── Servidor ─────────────────────────────────────────────────────────────────
PORT=8080
# Desarrollo local: 127.0.0.1 | Docker/Producción (detrás de reverse proxy): 0.0.0.0
SERVER_ADDR=127.0.0.1

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_EXPIRATION=3600
# Generar con: openssl rand -base64 64
API_JWT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_BASE64_64
API_JWT_SECRET_REFRESH=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_BASE64_64
# Rutas de claves RSA (generadas con openssl genrsa 4096)
API_JWT_PRIVATE_PEM_PATH=./pem/jwt_private.pem
API_JWT_PUBLIC_PEM_PATH=./pem/jwt_public.pem

# ─── Cookies ──────────────────────────────────────────────────────────────────
# Desarrollo sin HTTPS: false | Producción con HTTPS: true (OBLIGATORIO)
COOKIE_SECURE=false

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Lista de orígenes separados por coma. NO usar * en producción
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ─── Logging ──────────────────────────────────────────────────────────────────
# Niveles: off | error | warn | info | debug | trace
LOG_LEVEL=info
RUST_LOG=info

# ─── Zona horaria ─────────────────────────────────────────────────────────────
APP_TIMEZONE=America/Mexico_City
