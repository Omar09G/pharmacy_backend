# Example environment variables (DO NOT commit secrets)
DATABASE_URL=postgres://postgres:password@localhost:5432/postgres?options=--search_path=pharmacy
PORT=8080
SERVER_ADDR=0.0.0.0
JWT_EXPIRATION=3600
LOG_LEVEL=info
RUST_LOG=info
PASSWORD_SALT=your_password_salt
# Use either HMAC secrets or RSA PEMs. Prefer HMAC until RSA vulnerability is addressed.
API_JWT_PRIVATE_PEM_PATH=./pem/jwt_private.pem
API_JWT_PUBLIC_PEM_PATH=./pem/jwt_public.pem
API_JWT_SECRET=your_hmac_secret_here
API_JWT_SECRET_REFRESH=your_hmac_refresh_secret_here
