Authorization: Bearer {{accessToken}}
Content-Type: application/json;charset=UTF-8

{
	"id": 4,
    "name": "CLIENT",
    "description": "Permite gestionar las compras y el perfil del cliente",
    "createdAt": "2026-04-02T10:33:00Z"
}

